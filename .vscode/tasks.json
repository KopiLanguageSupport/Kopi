{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kopi: update extension",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/update-extension.sh",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      },
      "windows": {
        "command": "bash",
        "args": [
          "${workspaceFolder}/scripts/update-extension.sh"
        ]
      }
    },
    {
      "label": "kopi: run example",
      "type": "shell",
      "command": "python3",
      "args": [
        "main.kopi",
        "examples/basics.kopi"
      ],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    }
  ]
}
