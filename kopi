#!/bin/bash

# Kopi language interpreter wrapper
# Usage: kopi <command> [args]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "$1" in
    run)
        shift
        if [ -z "$1" ]; then
            echo "Usage: kopi run <file.kopi>"
            exit 1
        fi
        exec python3 "$SCRIPT_DIR/main.kopi" "$@"
        ;;
    update)
        exec "$SCRIPT_DIR/scripts/update-extension.sh"
        ;;
    "")
        echo "Usage: kopi <command> [args]"
        echo "Commands:"
        echo "  run <file.kopi>    - Run a Kopi program"
        echo "  update             - Update the VS Code extension"
        exit 1
        ;;
    *)
        # If argument doesn't match a command and looks like a file, treat it as 'run'
        if [ -f "$1" ]; then
            exec python3 "$SCRIPT_DIR/main.kopi" "$@"
        else
            echo "Unknown command: $1"
            echo "Usage: kopi <command> [args]"
            echo "Commands:"
            echo "  run <file.kopi>    - Run a Kopi program"
            echo "  update             - Update the VS Code extension"
            exit 1
        fi
        ;;
esac
