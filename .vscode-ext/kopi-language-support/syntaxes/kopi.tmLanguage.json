{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kopi",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#number"
    },
    {
      "include": "#keyword"
    },
    {
      "include": "#builtin"
    },
    {
      "include": "#operator"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.kopi",
          "match": "#.*$"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.kopi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kopi",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.kopi",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.kopi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.kopi",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.kopi",
          "match": "\\b(if|else|while|for|def|let|return|break|continue)\\b"
        }
      ]
    },
    "builtin": {
      "patterns": [
        {
          "name": "support.function.builtin.kopi",
          "match": "\\b(print|read|len|range|type|str|int|float|bool|list|dict|set|append|pop|remove|clear|keys|values|items)\\b"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.kopi",
          "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<|>|and|or|not|=)"
        }
      ]
    }
  },
  "scopeName": "source.kopi"
}
